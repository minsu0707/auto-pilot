{
  "providers": [
    {
      "id": "google-oauth",
      "displayName": "Google OAuth",
      "triggerRules": [
        {
          "field": "auth_mode",
          "matchAny": [
            "google",
            "google login",
            "google oauth",
            "sign in with google"
          ]
        }
      ],
      "requiredEnvVars": [
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXT_PUBLIC_SITE_URL"
      ],
      "optionalEnvVars": [],
      "inputLabels": {
        "GOOGLE_CLIENT_ID": "Google OAuth client ID",
        "GOOGLE_CLIENT_SECRET": "Google OAuth client secret",
        "NEXT_PUBLIC_SITE_URL": "Public site URL used for OAuth redirects"
      },
      "validationRules": {
        "GOOGLE_CLIENT_ID": {
          "kind": "non-empty"
        },
        "GOOGLE_CLIENT_SECRET": {
          "kind": "non-empty"
        },
        "NEXT_PUBLIC_SITE_URL": {
          "kind": "url"
        }
      },
      "setupChecklist": [
        "Create or open the Google Cloud project for this app.",
        "Create an OAuth client for a web application.",
        "Add the app's public URL and callback URL to the authorized origins and redirect URIs.",
        "Copy the client ID and client secret into the project env file."
      ],
      "docsLinks": [
        "https://console.cloud.google.com/apis/credentials"
      ]
    },
    {
      "id": "supabase",
      "displayName": "Supabase",
      "triggerRules": [
        {
          "field": "auth_mode",
          "matchAny": [
            "supabase",
            "supabase auth"
          ]
        },
        {
          "field": "data_store",
          "matchAny": [
            "supabase"
          ]
        }
      ],
      "requiredEnvVars": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "optionalEnvVars": [],
      "inputLabels": {
        "NEXT_PUBLIC_SUPABASE_URL": "Supabase project URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY": "Supabase anon/public key",
        "SUPABASE_SERVICE_ROLE_KEY": "Supabase service role key"
      },
      "validationRules": {
        "NEXT_PUBLIC_SUPABASE_URL": {
          "kind": "url"
        },
        "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
          "kind": "non-empty"
        },
        "SUPABASE_SERVICE_ROLE_KEY": {
          "kind": "non-empty"
        }
      },
      "setupChecklist": [
        "Create or open the Supabase project for this app.",
        "Copy the project URL and anon key from Project Settings > API.",
        "Copy the service role key only if the app needs privileged server-side access.",
        "Keep the service role key out of client-side code and store it only in the project env file."
      ],
      "docsLinks": [
        "https://supabase.com/dashboard/project/_/settings/api"
      ]
    }
  ]
}
